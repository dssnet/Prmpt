{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "window-*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "sql:default",
    "sql:allow-execute",
    "stronghold:default",
    "stronghold:allow-remove-store-record",
    "updater:default",
    "process:allow-restart"
  ]
}
