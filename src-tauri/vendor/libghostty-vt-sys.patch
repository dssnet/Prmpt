+/// prmpt: pick the concrete library filename in `lib_dir`. iOS uses the
+/// merged static archive; other static/dynamic builds reuse upstream's
+/// `LinkMode::matches_library` predicate to find the (version-suffixed)
+/// artifact rather than hard-coding a version.
+fn pick_lib_filename(
+    lib_dir: &Path,
+    target: &str,
+    link_mode: LinkMode,
+    is_ios: bool,
+) -> String {
+    if is_ios {
+        return "libghostty-vt-ios.a".to_owned();
+    }
+    std::fs::read_dir(lib_dir)
+        .unwrap_or_else(|error| panic!("failed to read {}: {error}", lib_dir.display()))
+        .filter_map(|entry| entry.ok())
+        .map(|entry| entry.file_name())
+        .filter_map(|name| name.to_str().map(str::to_owned))
+        .find(|name| link_mode.matches_library(target, name))
+        .unwrap_or_else(|| {
+            panic!(
+                "no libghostty-vt {} found in {}",
+                link_mode.artifact_kind(),
+                lib_dir.display()
+            )
+        })
+}
