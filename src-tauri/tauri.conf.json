{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prmpt",
  "version": "0.3.0",
  "identifier": "de.dss-net.prmpt",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prmpt",
        "width": 960,
        "height": 600,
        "transparent": false,
        "backgroundColor": "#1e1e2e",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "native/libghostty-vt.dylib"
      ]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dssnet/Prmpt/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyNEFEN0VENURGMzA3NEYKUldSUEIvTmQ3ZGRLSWhJazBSWmViaGFmYnRnT3JFbHRtRkdZVVZ5NFB0ZWZyUTZMNmQ1YTcwVGEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
